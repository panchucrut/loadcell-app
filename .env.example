# Copiar como .env y completar valores reales
SECRET_KEY=genera-uno-con: python3 -c "import secrets; print(secrets.token_hex(32))"
ALLOWED_ORIGINS=https://sensores.dexfloor.com,http://localhost:5050

# Azure AD (F6)
AZURE_CLIENT_ID=tu-client-id
AZURE_CLIENT_SECRET=tu-client-secret
AZURE_TENANT_ID=tu-tenant-id
AZURE_REDIRECT_URI=https://sensores.dexfloor.com/auth/callback
